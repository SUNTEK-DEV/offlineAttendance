<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 按下状态 -->
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape>
                    <solid android:color="#CC006666" />
                    <corners android:radius="4dp" />
                </shape>
            </item>
            <item android:left="2dp"
                  android:top="2dp"
                  android:right="2dp"
                  android:bottom="2dp">
                <shape>
                    <stroke
                        android:width="1dp"
                        android:color="#00FFFF" />
                    <corners android:radius="4dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- 默认状态 -->
    <item>
        <layer-list>
            <item>
                <shape>
                    <solid android:color="#80003333" />
                    <corners android:radius="4dp" />
                </shape>
            </item>
            <item android:left="2dp"
                  android:top="2dp"
                  android:right="2dp"
                  android:bottom="2dp">
                <shape>
                    <stroke
                        android:width="1dp"
                        android:color="#00FFFF" />
                    <corners android:radius="4dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>