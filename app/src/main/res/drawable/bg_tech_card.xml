<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 主体背景 -->
    <item>
        <shape>
            <solid android:color="#B0001133" />
            <corners android:radius="8dp" />
            <stroke
                android:width="1dp"
                android:color="#00FFFF" />
        </shape>
    </item>

    <!-- 四角装饰 -->
    <item android:left="-2dp"
          android:top="-2dp"
          android:right="-2dp"
          android:bottom="-2dp">
        <shape>
            <stroke
                android:width="2dp"
                android:color="#00FFFF"
                android:dashWidth="8dp"
                android:dashGap="4dp" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</layer-list>
