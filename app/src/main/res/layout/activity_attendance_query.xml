<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0a1a"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="16dp"
        android:text="Attendance Management"
        android:textColor="#00FFFF"
        android:textSize="24sp"
        android:textStyle="bold" />

    <com.arcsoft.arcfacedemo.widget.TechClockView
        android:id="@+id/tech_clock"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_tech_card"
        android:gravity="center"
        android:padding="12dp"
        android:text="Note: Please use [Face Attendance] for check-in. Employee management is in [Employee Management]"
        android:textColor="#00CCCC"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_list_employees"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_tech_button"
            android:text="Employee List"
            android:textColor="#00FFFF" />

        <Button
            android:id="@+id/btn_query_records"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_tech_button"
            android:text="Attendance Records"
            android:textColor="#00FFFF" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_generate_report"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_tech_button"
        android:text="Generate Attendance Report"
        android:textColor="#00FFFF" />

    <Button
        android:id="@+id/btn_export_excel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_tech_button"
        android:enabled="false"
        android:text="Export Report to Excel"
        android:textColor="#00FFFF" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        android:background="@drawable/bg_tech_card"
        android:padding="16dp">

        <TextView
            android:id="@+id/tv_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="4dp"
            android:text="Query results will be displayed here...&#10;&#10;Click buttons above to view employee list or attendance records"
            android:textColor="#00CCCC"
            android:textSize="14sp" />
    </ScrollView>

</LinearLayout>