<?xml version="1.0" encoding="utf-8"?>
<layout>

    <FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/dual_camera_ll_parent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000">

        <!-- 科技感渐变背景 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_tech_gradient" />

        <FrameLayout
            android:id="@+id/camera_preview_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="top"
            android:clipChildren="true">

            <TextureView
                android:id="@+id/dual_camera_texture_preview_rgb"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <com.arcsoft.arcfacedemo.widget.FaceRectView
                android:id="@+id/dual_camera_face_rect_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- 科技感扫描线 -->
            <View
                android:id="@+id/scan_line"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@drawable/bg_scan_line"
                android:visibility="gone" />

            <!-- 四角科技装饰 -->
            <View
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="top|start"
                android:layout_margin="16dp"
                android:background="@drawable/bg_corner_tech" />
            <View
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="top|end"
                android:layout_margin="16dp"
                android:rotation="90"
                android:background="@drawable/bg_corner_tech" />
            <View
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="bottom|start"
                android:layout_margin="16dp"
                android:rotation="-90"
                android:background="@drawable/bg_corner_tech" />
            <View
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="16dp"
                android:rotation="180"
                android:background="@drawable/bg_corner_tech" />

            <FrameLayout
                android:id="@+id/fl_recognize_ir"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom">

                <TextureView
                    android:id="@+id/dual_camera_texture_preview_ir"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <com.arcsoft.arcfacedemo.widget.FaceRectView
                    android:id="@+id/dual_camera_face_rect_view_ir"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

            </FrameLayout>

        </FrameLayout>

        <!-- RecyclerView用于显示识别结果列表 - 放在较早位置，不覆盖控制按钮 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/dual_camera_recycler_view_person"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="false"
            android:focusable="false"
            android:focusableInTouchMode="false"
            app:compareResultList="@{compareResultList}" />

        <!-- 顶部状态栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingTop="24dp"
            android:paddingEnd="20dp"
            android:paddingBottom="12dp"
            android:background="@drawable/bg_top_bar_gradient">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Face Recognition System"
                android:textSize="18sp"
                android:textColor="#00FFFF"
                android:textStyle="bold"
                android:shadowColor="#00FFFF"
                android:shadowRadius="8" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● System Online"
                android:textSize="14sp"
                android:textColor="#00FF00"
                android:shadowColor="#00FF00"
                android:shadowRadius="6" />

        </LinearLayout>

        <!-- 底部控制按钮区域 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:padding="16dp">

            <!-- 左下角隐藏管理员区域（连续点击 5 次触发） -->
            <View
                android:id="@+id/btn_admin_login"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="bottom|start"
                android:onClick="onAdminClick"
                android:background="@android:color/transparent" />

            <!-- 右下角切换打卡方式按钮 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:background="@drawable/bg_control_panel"
                android:padding="12dp"
                android:elevation="10dp"
                android:clickable="true"
                android:focusable="true">

                <Button
                    android:id="@+id/btn_switch_check_in_mode"
                    android:layout_width="160dp"
                    android:layout_height="80dp"
                    android:onClick="switchCheckInMode"
                    android:text="@string/switch_check_in_mode"
                    android:textColor="#00FFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_tech_button"
                    android:stateListAnimator="@null"
                    android:elevation="8dp" />

            </LinearLayout>
        </FrameLayout>

        <!-- 识别结果提示 -->
        <TextView
            android:id="@+id/recognize_notice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center"
            android:layout_marginBottom="120dp"
            android:background="@drawable/bg_notice_panel"
            android:paddingStart="24dp"
            android:paddingTop="12dp"
            android:paddingEnd="24dp"
            android:paddingBottom="12dp"
            android:text="@{recognizeNotice}"
            android:textColor="#00FF00"
            android:textSize="20sp"
            android:textStyle="bold"
            android:shadowColor="#00FF00"
            android:shadowRadius="10"
            android:elevation="5dp"
            android:visibility="@{(recognizeNotice == null || recognizeNotice.length() == 0)?View.GONE:View.VISIBLE}" />

    </FrameLayout>

    <data>

        <variable
            name="compareResultList"
            type="java.util.List&lt;com.arcsoft.arcfacedemo.ui.model.CompareResult&gt;" />

        <variable
            name="recognizeNotice"
            type="String" />

        <variable
            name="drawRectInfoText"
            type="String" />

        <import type="android.view.View" />
    </data>
</layout>