<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 科技风主题 -->
    <style name="TechTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/tech_primary</item>
        <item name="colorPrimaryDark">@color/tech_bg_medium</item>
        <item name="colorAccent">@color/tech_primary</item>
        <item name="android:windowBackground">@color/tech_bg_dark</item>
        <item name="android:textColor">@color/tech_text_primary</item>
        <item name="android:statusBarColor">@color/tech_bg_medium</item>
    </style>

    <!-- 标题样式 -->
    <style name="TechTextTitle">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/tech_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:shadowColor">@color/tech_primary</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
        <item name="android:shadowRadius">8</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

    <style name="TechTextSubtitle">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/tech_primary_light</item>
        <item name="android:textStyle">bold</item>
        <item name="android:shadowColor">@color/tech_primary</item>
        <item name="android:shadowRadius">6</item>
    </style>

    <!-- 正文样式 -->
    <style name="TechTextBody">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/tech_text_secondary</item>
    </style>

    <style name="TechTextBodyBold">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/tech_text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- 小字样式 -->
    <style name="TechTextCaption">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/tech_text_hint</item>
    </style>

    <!-- 状态文字样式 -->
    <style name="TechTextStatusSuccess">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/tech_success</item>
        <item name="android:textStyle">bold</item>
        <item name="android:shadowColor">@color/tech_success</item>
        <item name="android:shadowRadius">6</item>
    </style>

    <style name="TechTextStatusWarning">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/tech_warning</item>
        <item name="android:textStyle">bold</item>
        <item name="android:shadowColor">@color/tech_warning</item>
        <item name="android:shadowRadius">6</item>
    </style>

    <style name="TechTextStatusError">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/tech_error</item>
        <item name="android:textStyle">bold</item>
        <item name="android:shadowColor">@color/tech_error</item>
        <item name="android:shadowRadius">6</item>
    </style>

    <!-- 按钮样式 -->
    <style name="TechButton">
        <item name="android:background">@drawable/bg_tech_button</item>
        <item name="android:textColor">@color/tech_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingLeft">24dp</item>
        <item name="android:paddingRight">24dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="TechButtonPrimary">
        <item name="android:background">@drawable/bg_tech_button_primary</item>
        <item name="android:textColor">@color/tech_bg_dark</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingLeft">24dp</item>
        <item name="android:paddingRight">24dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="TechButtonIcon">
        <item name="android:background">@drawable/bg_tech_button_icon</item>
        <item name="android:minWidth">48dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:padding">0dp</item>
    </style>

    <!-- 卡片样式 -->
    <style name="TechCard">
        <item name="android:background">@drawable/bg_tech_card</item>
        <item name="android:padding">16dp</item>
        <item name="android:elevation">0dp</item>
    </style>

    <!-- 输入框样式 -->
    <style name="TechEditText">
        <item name="android:background">@drawable/bg_tech_edittext</item>
        <item name="android:textColor">@color/tech_primary</item>
        <item name="android:textColorHint">@color/tech_text_hint</item>
        <item name="android:padding">16dp</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- 工具栏样式 -->
    <style name="TechToolbar" parent="Widget.AppCompat.Toolbar">
        <item name="android:background">@drawable/bg_tech_status_bar</item>
        <item name="titleTextColor">@color/tech_primary</item>
        <item name="android:elevation">0dp</item>
    </style>

    <!-- 进度条样式 -->
    <style name="TechProgressBar">
        <item name="android:progressDrawable">@drawable/progress_tech</item>
        <item name="android:minHeight">8dp</item>
    </style>
</resources>
